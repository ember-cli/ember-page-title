{
  "name": "docs",
  "type": "module",
  "private": true,
  "description": "Page Titles for Ember applications",
  "keywords": [
    "page title",
    "title",
    "component"
  ],
  "license": "MIT",
  "author": "Tim Evans <tim.c.evans@me.com>",
  "repository": "https://github.com/ember-cli/ember-page-title",
  "scripts": {
    "build": "vite build",
    "format:hbs": "prettier **/*.hbs --write --parser=glimmer",
    "format:js": "prettier **/*.js --write",
    "lint": "npm-run-all --aggregate-output --continue-on-error --parallel \"lint:!(fix)\"",
    "lint:fix": "npm-run-all --aggregate-output --continue-on-error --parallel lint:*:fix",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:types": "ember-tsc",
    "start": "vite",
    "test:ember": "vite build --mode development && ember test --path dist"
  },
  "dependencies": {
    "ember-page-title": "workspace:*"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.23.3",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/plugin-transform-typescript": "^7.28.6",
    "@ember/app-tsconfig": "^2.0.0",
    "@ember/optional-features": "^3.0.0",
    "@ember/string": "^4.0.1",
    "@ember/test-helpers": "^5.4.1",
    "@embroider/core": "^4.4.7",
    "@embroider/legacy-inspector-support": "^0.1.3",
    "@embroider/vite": "^1.7.2",
    "@glimmer/component": "^2.1.1",
    "@glimmer/tracking": "^1.0.4",
    "@glint/ember-tsc": "^1.5.0",
    "@glint/template": "^1.7.7",
    "@glint/tsserver-plugin": "^2.4.0",
    "@rollup/plugin-babel": "^6.1.0",
    "@types/qunit": "^2.19.9",
    "@types/rsvp": "^4.0.8",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "babel-plugin-ember-template-compilation": "^3.1.0",
    "concurrently": "^8.2.2",
    "decorator-transforms": "^2.3.1",
    "ember-qunit": "^9.0.4",
    "ember-resolver": "^13.2.0",
    "ember-source": "~6.12.0",
    "ember-source-channel-url": "^3.0.0",
    "ember-strict-application-resolver": "^0.1.1",
    "ember-template-lint": "^6.1.0",
    "ember-truth-helpers": "^5.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-ember": "^12.5.0",
    "eslint-plugin-jsonc": "^2.11.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "eslint-plugin-qunit": "^8.0.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.1.1",
    "qunit": "^2.16.0",
    "sass": "^1.43.3",
    "typescript": "^6.0.2",
    "vite": "^7.3.1",
    "vite-ember-ssr": "0.1.0-alpha.13"
  },
  "engines": {
    "node": ">= 24"
  },
  "ember": {
    "edition": "octane"
  },
  "homepage": "https://ember-cli.github.io/ember-page-title",
  "volta": {
    "extends": "../package.json"
  },
  "exports": {
    "./tests/*": "./tests/*",
    "./*": "./app/*"
  }
}
